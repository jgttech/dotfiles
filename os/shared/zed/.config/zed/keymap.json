[
  {
    "context": "vim_mode == normal && !menu",
    "bindings": {
      "shift-l": "pane::ActivateNextItem",
      "shift-h": "pane::ActivatePreviousItem",
      "shift-q": null,
      "[ d": "editor::GoToPreviousDiagnostic",
      "] d": "editor::GoToDiagnostic",
      "space e": "editor::Hover",
      "space f": "diagnostics::Deploy",
      "space h": "workspace::ActivatePaneLeft",
      "space l": "workspace::ActivatePaneRight",
      "space k": "workspace::ActivatePaneUp",
      "space j": "workspace::ActivatePaneDown",
      "space s v": "pane::SplitRight",
      "space s h": "pane::SplitDown",
      "space q": "pane::CloseActiveItem",
      "space shift-q": "pane::CloseInactiveItems",
      "space escape escape": "zed::Quit",
      "ctrl-\\": "workspace::NewCenterTerminal",
    },
  },
  {
    "context": "vim_mode == visual",
    "bindings": {
      "shift-j": "editor::MoveLineDown",
      "shift-k": "editor::MoveLineUp",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-\\": "pane::CloseActiveItem",
    },
  },
]
