{
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "project_panel": {
    "dock": "right",
  },
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "git_panel": {
    "dock": "right",
  },
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "settings": {
        "context7_api_key": "${CONTEXT7_API_KEY}",
      },
    },
  },
  "agent_buffer_font_size": 12,
  "agent": {
    "dock": "left",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-4.1",
      "enable_thinking": false,
    },
  },
  "edit_predictions": {
    "provider": "copilot",
    "mode": "eager",
  },
  "vim_mode": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "theme": "Kanagawa Wave",
  "hide_mouse": "on_typing",
  "minimap": {
    "current_line_highlight": "all",
  },
  "relative_line_numbers": "enabled",
  "remove_trailing_whitespace_on_save": true,
  "format_on_save": "on",
  "toolbar": {
    "breadcrumbs": true,
  },
  "buffer_font_size": 15,
  "buffer_font_family": "MesloLGS NF",
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true,
    },
  },
  "terminal": {
    "font_family": "MesloLGS NF",
    "working_directory": "current_project_directory",
  },
  "languages": {
    "Python": {
      "indent_guides": {
        "enabled": true,
      },
    },
  },
}
