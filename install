#!/usr/bin/env bash
set -euo pipefail
repo="https://github.com/jgttech/dotfiles.git"
cwd="$(pwd)"

# Parse args: filter out --yes/-y before positional parses.
YES=false
positional=()
for arg in "$@"; do
  case "$arg" in
    -y|--yes) YES=true ;;
    *) positional+=("$arg") ;;
  esac
done
set -- ${positional[@]+"${positional[@]}"}

# Which branch to checkout.
branch="${1:-"latest"}"

# Where to download it to.
dir="${2:-"$HOME/.dotfiles"}"

# The environment config for install.
env_dotfiles="$dir/.env.dotfiles"

# Common install locations a binary may live in that aren't yet on PATH —
# typical right after a fresh install where the user hasn't restarted their shell.
_extra_bindirs=(
  "/opt/homebrew/bin"                     # Homebrew (Apple Silicon)
  "/opt/homebrew/sbin"
  "/usr/local/bin"                        # Homebrew (Intel) / generic
  "/usr/local/sbin"
  "$HOME/.local/bin"                      # XDG user bin (devbox installer lands here)
  "$HOME/bin"                             # legacy user bin
  "$HOME/.cargo/bin"                      # rust / cargo install
  "$HOME/go/bin"                          # go install
  "$HOME/.nix-profile/bin"                # nix profile (single-user)
  "/nix/var/nix/profiles/default/bin"     # nix profile (multi-user)
)

# True if $1 is invokable, including in common install locations not yet on PATH.
installed() {
  local cmd="$1" d

  # Layer 1: PATH (binaries, shims, functions, aliases, builtins).
  command -v "$cmd" >/dev/null 2>&1 && return 0

  # Layer 2: common install locations that may not be on PATH yet.
  for d in "${_extra_bindirs[@]}"; do
    if [[ -x "$d/$cmd" ]]; then
      echo "[hint] Found '$cmd' at $d/$cmd — not on PATH yet." >&2
      echo "       Open a new shell or 'export PATH=\"$d:\$PATH\"' to use it." >&2
      return 0
    fi
  done

  return 1
}

# Dependencies needed to run the install process. Order is install-order so
# the list shown to the user reads as the dependency chain.
dependencies=( \
  "brew" \
  "devbox" \
  "just" \
  "yq" \
  "git" \
)

# Maps a dependency to the channel the bootstrap will use to install it.
install_tag() {
  case "$1" in
    brew)   echo "curl" ;;
    devbox) echo "curl" ;;
    just)   echo "brew" ;;
    yq)     echo "devbox" ;;
    git)    echo "xcode-select" ;;
    *)      echo "unknown" ;;
  esac
}

# Yes/no prompt that reads from /dev/tty so it works under `curl ... | bash`
# (where stdin is the curl pipe, not the user's terminal).
prompt_yn() {
  local prompt="$1" answer
  if [[ ! -e /dev/tty ]]; then
    echo "[ERROR] No terminal attached; re-run with --yes to skip the prompt." >&2
    return 1
  fi
  read -p "$prompt [Y/n] " answer < /dev/tty
  case "$answer" in
    n|N|no|NO|No) return 1 ;;
    *) return 0 ;;
  esac
}

missing=()
for dep in "${dependencies[@]}"; do
  if ! installed "$dep"; then
    missing+=("$dep")
  fi
done

if [[ ${#missing[@]} -ne 0 ]]; then
  echo "Missing required dependencies:"
  for dep in "${missing[@]}"; do
    printf '  - (%s) %s\n' "$(install_tag "$dep")" "$dep"
  done
  echo

  # Locate the bootstrap script relative to this install file.
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" 2>/dev/null && pwd)" || script_dir=""
  bootstrap_script=""
  if [[ -n "$script_dir" && -f "$script_dir/bin/scripts/bootstrap/main.sh" ]]; then
    bootstrap_script="$script_dir/bin/scripts/bootstrap/main.sh"
  fi

  if [[ -z "$bootstrap_script" ]]; then
    echo "[ERROR] Bootstrap script unavailable in this context." >&2
    echo "Install the listed dependencies manually and re-run." >&2
    exit 1
  fi

  if [[ "$YES" != "true" ]]; then
    if ! prompt_yn "Run the dotfiles bootstrap to install these for you?"; then
      echo "Aborted."
      exit 1
    fi
  fi

  echo
  if [[ "$YES" == "true" ]]; then
    bash "$bootstrap_script" --yes
  else
    bash "$bootstrap_script"
  fi

  remaining=()
  for dep in "${missing[@]}"; do
    if ! installed "$dep"; then
      remaining+=("$dep")
    fi
  done

  if [[ ${#remaining[@]} -ne 0 ]]; then
    echo
    echo "[ERROR] Bootstrap completed but the following are still missing:"
    for dep in "${remaining[@]}"; do
      printf '  - %s\n' "$dep"
    done
    echo
    echo "If Xcode Command Line Tools are still installing, complete the GUI dialog and re-run." >&2
    exit 1
  fi

  echo
fi

pre_existing=false

if [[ ! -d "$dir" ]]; then
  git clone $repo $dir
else
  pre_existing=true
fi

# We simply can't do anything if the environment config doesn't exist.
if [[ ! -f "$env_dotfiles" ]]; then
  echo "Missing REQUIRED environment config:"
  echo -e "$env_dotfiles\n"
  echo "Please ensure the dotfiles was downloaded"
  echo "correctly and try again with the following:"
  echo "\$ bash install"
  exit 1
else
  source "$env_dotfiles"
fi

cd $dir
git checkout $branch

# Path to the build.
build="$dir/$(yq -r '.build' "$DOTFILES_CONFIG")"

if $pre_existing; then
  # Ensure latest
  git fetch >&2
  git pull >&2

  # If it exists, we have installed it already. Because there
  # can be changes between installs, we need to FIRST uninstall
  # to make sure we are in a clean state before we re-install.
  if [[ -d "$build" ]]; then
    just uninstall

    # Triggers a new build.
    rm -rf "$build"
  fi
fi

# The build will happen automatically, as needed.
just install

# Put the user back where they started from.
cd "$cwd"
